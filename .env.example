# Скопируйте в .env и заполните своими значениями:  cp .env.example .env
# Файл .env НЕ коммитить в git (см. .gitignore).

# Домен, на который Caddy получит HTTPS-сертификат и будет отдавать лендинг
DOMAIN=example.com

# Разрешённый Origin для формы (обычно = https://DOMAIN). Пусто = не проверять.
ALLOWED_ORIGIN=https://example.com

# Длинный случайный токен для скачивания CSV.
# Сгенерировать:  openssl rand -hex 32
ADMIN_TOKEN=replace_me_with_long_random_hex
